APP_ENV=development
HTTP_ADDR=:8080
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/catwa?sslmode=disable
CORS_ALLOWED_ORIGINS=https://catwa.chat,https://www.catwa.chat,http://localhost:1420,http://127.0.0.1:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost,app://localhost
WS_ALLOWED_ORIGINS=https://catwa.chat,https://www.catwa.chat,http://localhost:1420,http://127.0.0.1:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost,app://localhost
WS_ALLOW_EMPTY_ORIGIN=true
WS_NOTIFY_CHANNEL=catwa_realtime_events
TRUSTED_PROXY_CIDRS=127.0.0.1/8,::1/128
WS_HEARTBEAT_INTERVAL=15s
WS_RECONNECT_AFTER=2s
WS_TYPING_TIMEOUT=5s
WS_QUEUE_SIZE=256
WS_MAX_MESSAGE_SIZE=1048576
LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_PUBLIC_URL=wss://livekit.catwa.chat
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
VOICE_ROOM_PREFIX=catwa-voice-
VOICE_TOKEN_TTL=5m
VOICE_MAX_CAPACITY=10
VOICE_DISCONNECT_GRACE=30s
JWT_ISSUER=catwa
JWT_AUDIENCE=catwa-client
JWT_ACCESS_SECRET=dev_access_secret_change_this_1234567890
JWT_REFRESH_SECRET=dev_refresh_secret_change_this_1234567890
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
STORAGE_PATH=./storage
UPLOADS_PATH=./storage/uploads
MAX_UPLOAD_BYTES=10485760
UPLOAD_ACCESS_SECRET=dev_upload_access_secret_change_this_1234567890
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_ENFORCE_SERVER_INVITE=false
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30
